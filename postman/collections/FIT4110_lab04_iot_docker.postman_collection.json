{
  "info": {
    "name": "FIT4110 Lab04 Analytics Docker Verification",
    "description": "The Postman collection updated to match the exact FastAPI schema parameters and custom X-Auth-Token headers required by the backend implementation.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "item": [
    {
      "name": "01_Functional",
      "item": [
        {
          "name": "GET health returns 200",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "http://localhost:8005/health",
              "protocol": "http",
              "host": [
                "localhost"
              ],
              "port": "8005",
              "path": [
                "health"
              ]
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Status code is 200', function () { pm.response.to.have.status(200); });",
                  "pm.test('Response has status ok', function () { const json = pm.response.json(); pm.expect(json.status).to.eql('ok'); });",
                  "pm.test('Response has service name and version', function () { const json = pm.response.json(); pm.expect(json).to.have.property('service'); pm.expect(json).to.have.property('version'); });"
                ]
              }
            }
          ]
        },
        {
          "name": "POST valid temperature reading returns 201",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "X-Auth-Token",
                "value": "local-dev-token"
              },
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "url": {
              "raw": "http://localhost:8005/readings",
              "protocol": "http",
              "host": [
                "localhost"
              ],
              "port": "8005",
              "path": [
                "readings"
              ]
            },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"device_id\": \"ESP32-LAB-A01\",\n  \"temperature\": 31.5,\n  \"humidity\": 65.0\n}"
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Status code is 201', function () { pm.response.to.have.status(201); });",
                  "pm.test('Response follows created-reading schema', function () { const json = pm.response.json(); pm.expect(json).to.have.property('reading_id'); pm.expect(json).to.have.property('status', 'created'); });",
                  "pm.test('Response device_id matches request', function () { const json = pm.response.json(); pm.expect(json.device_id).to.eql('ESP32-LAB-A01'); });",
                  "const created = pm.response.json();",
                  "if (created.reading_id) { pm.environment.set('createdReadingId', created.reading_id); }"
                ]
              }
            }
          ]
        },
        {
          "name": "GET latest readings returns items array",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "http://localhost:8005/readings/latest?device_id=ESP32-LAB-A01&limit=5",
              "protocol": "http",
              "host": [
                "localhost"
              ],
              "port": "8005",
              "path": [
                "readings",
                "latest"
              ],
              "query": [
                {
                  "key": "device_id",
                  "value": "ESP32-LAB-A01"
                },
                {
                  "key": "limit",
                  "value": "5"
                }
              ]
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Status code is 200', function () { pm.response.to.have.status(200); });",
                  "pm.test('Response has items array', function () { const json = pm.response.json(); pm.expect(json).to.have.property('items'); pm.expect(json.items).to.be.an('array'); });"
                ]
              }
            }
          ]
        },
        {
          "name": "GET reading by saved reading_id returns 200",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "http://localhost:8005/readings/{{createdReadingId}}",
              "protocol": "http",
              "host": [
                "localhost"
              ],
              "port": "8005",
              "path": [
                "readings",
                "{{createdReadingId}}"
              ]
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Status code is 200', function () { pm.response.to.have.status(200); });",
                  "pm.test('Response reading_id matches saved variable', function () { const json = pm.response.json(); const saved = pm.environment.get('createdReadingId') || 'mock-uuid-12345'; pm.expect(json.reading_id).to.eql(saved); });"
                ]
              }
            }
          ]
        }
      ]
    },
